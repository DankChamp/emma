# Copy this file to .env and fill in what you actually have.
# Blank = that provider is disabled, Emma just won't route to it.

DEBUG=true

GROQ_API_KEY=
NVIDIA_NIM_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Generic local provider - point this at ANY OpenAI-compatible local server:
# LM Studio (http://localhost:1234), llama.cpp's llama-server (http://localhost:8080),
# text-generation-webui, vLLM, KoboldCpp, LocalAI, etc. Leave blank to disable.
LOCAL_BASE_URL=
LOCAL_API_KEY=
LOCAL_DEFAULT_MODEL=

OLLAMA_DEFAULT_MODEL=llama3.1:8b
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile
NVIDIA_NIM_DEFAULT_MODEL=deepseek-ai/deepseek-v4-flash

PREFER_LOCAL_WHEN_AVAILABLE=true

# --- Voice (wake word + speech). Fully offline - see voice/README.md ---
VOICE_WAKE_WORD=hey emma
VOICE_BACKEND_URL=http://127.0.0.1:8000
# Path to an unzipped Vosk speech model, e.g. ./voice/models/vosk-model-small-en-us-0.15
VOICE_VOSK_MODEL_PATH=
# Leave blank to use the system's default microphone
VOICE_INPUT_DEVICE=

# --- How Emma sounds (text-to-speech) ---
# "auto" = natural neural Piper voice if installed, else the system voice.
# Get the good voice with:  python voice/download_voice.py
VOICE_TTS_ENGINE=auto
# Piper voice model: blank auto-picks a feminine voice from voice/models,
# or set a name like "en_US-amy-medium" / a full path to an .onnx file.
VOICE_PIPER_MODEL_PATH=
# Piper voice tuning (feminine defaults; tweak to taste):
VOICE_PIPER_LENGTH_SCALE=1.02
VOICE_PIPER_NOISE_SCALE=0.667
VOICE_PIPER_NOISE_W_SCALE=0.8
VOICE_PIPER_VOLUME=1.0

# Legacy system-voice knobs (only used when engine falls back to pyttsx3):
VOICE_TTS_RATE=175
# Substring match against a system voice name, e.g. "Zira", "Samantha", "en+f3"
VOICE_TTS_VOICE=

# --- Telegram notification bot ---
# Create a bot via @BotFather on Telegram and paste the token here.
TELEGRAM_BOT_TOKEN=
# Your Telegram user ID (so Emma knows who the owner is for commands):
EMMA_OWNER_TELEGRAM_ID=
# Your name as Emma should refer to you:
EMMA_OWNER_NAME=VOID

# --- Time zone (IANA name like Asia/Kolkata, America/New_York) ---
# Used to correctly schedule block notifications from local timetable times.
EMMA_TZ=Asia/Kolkata
